
# =========================================================

# Project Base — Environment Variables

# =========================================================

# Copie este arquivo para .env.local quando for desenvolver localmente.

#

# Nunca commitar .env, .env.local ou chaves reais.

# Nunca expor variáveis secretas com NEXT_PUBLIC_.

# =========================================================

# App

# URL pública do projeto em desenvolvimento.

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase

# URL pública do projeto Supabase.

NEXT_PUBLIC_SUPABASE_URL=

# Chave pública anon do Supabase.

# Pode ir para o frontend, desde que RLS esteja correta.

NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave secreta service role.

# Nunca usar no frontend.

SUPABASE_SERVICE_ROLE_KEY=

# Integrações futuras

# ABACATEPAY_API_KEY=

# ABACATEPAY_WEBHOOK_SECRET=

# WHATSAPP_API_TOKEN=

# GOOGLE_CLIENT_ID=

# GOOGLE_CLIENT_SECRET=

