# =========================================================
# Project Base — Environment Variables
# =========================================================
#
# Este arquivo é um modelo seguro para documentar variáveis.
#
# Ele deve ser versionado.
# Ele não deve conter chaves reais.
#
# Para desenvolvimento local, copie .env.local.example para .env.local.
#
# Nunca commitar:
# - .env
# - .env.local
# - .env.*.local
#
# Nunca colocar NEXT_PUBLIC_ em variável secreta.
# =========================================================


# =========================================================
# App
# =========================================================

# URL pública do projeto em desenvolvimento.
# Pode ser exposta no frontend.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Nome técnico do projeto.
# Exemplo: project-base, food-orders, worklog.
NEXT_PUBLIC_APP_SLUG=project-base

# Nome comercial exibido na interface.
# Exemplo: Project Base, Central de Pedidos Rukka.
NEXT_PUBLIC_APP_NAME=Project Base

# Ambiente atual.
# Valores comuns: development, staging, production.
NEXT_PUBLIC_APP_ENV=development


# =========================================================
# Supabase — Público
# =========================================================

# URL pública do projeto Supabase.
# Pode ser usada no frontend.
NEXT_PUBLIC_SUPABASE_URL=

# Chave anon pública do Supabase.
# Pode ir para o frontend desde que RLS esteja correta.
NEXT_PUBLIC_SUPABASE_ANON_KEY=


# =========================================================
# Supabase — Secreto
# =========================================================

# Chave service role do Supabase.
# Nunca usar no frontend.
# Nunca adicionar NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=


# =========================================================
# Auth / Google
# =========================================================

# Client ID pode ser público dependendo da implementação,
# mas mantenha documentado e revise antes de expor.
GOOGLE_CLIENT_ID=

# Client Secret é secreto.
# Nunca usar no frontend.
GOOGLE_CLIENT_SECRET=


# =========================================================
# Payments / AbacatePay
# =========================================================

# API Key secreta.
# Nunca usar no frontend.
ABACATEPAY_API_KEY=

# Secret usado para validar webhooks.
# Nunca usar no frontend.
ABACATEPAY_WEBHOOK_SECRET=


# =========================================================
# WhatsApp
# =========================================================

# Token secreto da API.
# Nunca usar no frontend.
WHATSAPP_API_TOKEN=

# ID do número/telefone, quando aplicável.
WHATSAPP_PHONE_NUMBER_ID=

# Token/secret para validar webhook.
WHATSAPP_WEBHOOK_SECRET=

# Verify token, quando exigido pela plataforma.
WHATSAPP_VERIFY_TOKEN=


# =========================================================
# Storage
# =========================================================

# Nome do bucket público, se existir.
NEXT_PUBLIC_STORAGE_PUBLIC_BUCKET=

# Nome do bucket privado.
STORAGE_PRIVATE_BUCKET=


# =========================================================
# Analytics
# =========================================================

# Ativar/desativar tracking em desenvolvimento.
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Chave pública de analytics, se houver.
NEXT_PUBLIC_ANALYTICS_KEY=


# =========================================================
# Feature Flags
# =========================================================

# Ativa modo de demonstração.
NEXT_PUBLIC_DEMO_MODE=true

# Ativa recursos experimentais.
NEXT_PUBLIC_ENABLE_EXPERIMENTS=false
