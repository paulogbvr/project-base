# =========================================================
# Project Base — Local Development Environment
# =========================================================
#
# Para usar:
#
# cp .env.local.example .env.local
#
# Depois preencha .env.local com valores reais.
#
# O .env.local está bloqueado no .gitignore e não deve ser commitado.
# =========================================================


# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_SLUG=project-base
NEXT_PUBLIC_APP_NAME=Project Base
NEXT_PUBLIC_APP_ENV=development


# Supabase público
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=


# Supabase secreto
SUPABASE_SERVICE_ROLE_KEY=


# Google Auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# AbacatePay
ABACATEPAY_API_KEY=
ABACATEPAY_WEBHOOK_SECRET=


# WhatsApp
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_VERIFY_TOKEN=


# Storage
NEXT_PUBLIC_STORAGE_PUBLIC_BUCKET=
STORAGE_PRIVATE_BUCKET=


# Analytics
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ANALYTICS_KEY=


# Feature Flags
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_ENABLE_EXPERIMENTS=false
